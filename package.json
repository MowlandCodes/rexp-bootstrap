{
  "name": "create-rexp",
  "version": "1.0.1",
  "description": "Scaffold a React + Express + Prisma full-stack monorepo",
  "type": "module",
  "bin": {
    "create-rexp": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir=dist --target=node --format=esm",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MowlandCodes/rexp-bootstrap"
  },
  "keywords": [
    "react",
    "express",
    "prisma",
    "fullstack",
    "monorepo",
    "scaffold"
  ],
  "license": "MIT",
  "author": "mowlandcodes"
}
